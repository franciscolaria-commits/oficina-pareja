generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  owner       String   // 'fran', 'novia', 'compartido'
  startTime   DateTime
  endTime     DateTime
  description String?
}

model TimelineMemory {
  id          Int      @id @default(autoincrement())
  imageUrl    String   
  memoryDate  DateTime 
  description String?
  uploadedBy  String   // 'fran' o 'novia'
  createdAt   DateTime @default(now()) 
}